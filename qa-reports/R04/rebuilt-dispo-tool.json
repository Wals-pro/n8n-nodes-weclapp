    {
      "id": "0d35893b-b383-464a-8334-a515695d869c",
      "name": "Code aggregate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [560, 160],
      "parameters": {
        "jsCode": "// Aggregate quantities by articleId across all incoming items.\nconst all = $input.all();\nconst sums = new Map();\n\nfor (const [index, item] of all.entries()) {\n  const list = item.json.orderitems ?? item.json.orderItems ?? [];\n  if (!Array.isArray(list)) continue;\n\n  for (const it of list) {\n    if (!it) continue;\n    const id = it.articleId ?? it.articleID ?? it.articleid;\n    if (id == null) continue;\n    const rawQty = it.quantity ?? it.qty ?? it.amount ?? 0;\n    const qty = typeof rawQty === 'string' ? parseFloat(rawQty) : Number(rawQty);\n    if (!Number.isFinite(qty)) continue;\n    const articleNumber = it.articleNumber ?? it.articlenumber ?? it.sku ?? null;\n    if (sums.has(id)) {\n      const existing = sums.get(id);\n      existing.quantity += qty;\n      if (!existing.articleNumber && articleNumber) existing.articleNumber = articleNumber;\n      existing.pairedItems.push({ item: index });\n    } else {\n      sums.set(id, { articleId: id, articleNumber, quantity: qty, pairedItems: [{ item: index }] });\n    }\n  }\n}\n\nconst out = Array.from(sums.values()).map(entry => ({\n  json: { id: entry.articleId, articleNumber: entry.articleNumber, minimumStockQuantity: entry.quantity },\n  pairedItem: entry.pairedItems,\n}));\nout.sort((a, b) => String(a.json.id).localeCompare(String(b.json.id)));\nreturn out;"
      }
    },
    {
