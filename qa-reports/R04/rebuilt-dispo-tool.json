    {
      "id": "93de3a38-46ef-41b7-be2f-debb627274c9",
      "name": "Code compute minimumStockQuantity",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1000, 240],
      "parameters": {
        "jsCode": "// Pre-compute the final minimumStockQuantity value before the PUT.\n// International category articles get 4x the calculated quantity.\nconst internationalCategoryIds = JSON.parse($('Constants').first().json.internationalCategoryIds);\n\nreturn $input.all().map((item, index) => {\n  const articleCategoryId = String(item.json.articleCategoryId ?? '');\n  const baseQty = Number(item.json.minimumStockQuantity ?? 0);\n  const isInternational = internationalCategoryIds.includes(articleCategoryId);\n  const computedMinStock = isInternational ? baseQty * 4 : baseQty;\n  return {\n    json: { ...item.json, computedMinStock },\n    pairedItem: { item: index },\n  };\n});"
      }
    },
    {
      "id": "c3a65493-d770-4090-b78c-34fa4b87a86f",
      "name": "article update minimumStockQuantity",
      "type": "n8n-nodes-weclapp.weclapp",
      "typeVersion": 1,
      "position": [1220, 240],
      "parameters": {
        "resource": "customApiCall",
        "operation": "call",
        "method": "PUT",
        "entityPath": "article",
        "entityId": "={{ $json.id }}",
        "queryParameters": {
          "parameter": [{"key": "ignoreMissingProperties", "value": "true"}]
        },
        "requestBody": "={{ JSON.stringify({ minimumStockQuantity: $json.computedMinStock }) }}"
      },
      "credentials": {
        "weclappApi": {"id": "jebRfSixFZZxu8qH", "name": "testhandel"}
      },
      "onError": "continueRegularOutput"
    },
