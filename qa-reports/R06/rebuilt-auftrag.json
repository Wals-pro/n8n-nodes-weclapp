    {
      "id": "28e53341-ab20-4b1f-9d9a-7dbb02968ebf",
      "name": "Code",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [112, 528],
      "parameters": {
        "jsCode": "// n8n Code node (JavaScript)\n// Source: items from \"Split Out salesOrders1\" (NOT $input)\n\nconst WAREHOUSE_ID_DEF = $('Edit Fields').first().json.WAREHOUSE_ID_DEF;\nconst CUSTOM_ATTR_CHECK_ID = $('Edit Fields').first().json.additionalField_KeinVersand;\nconst GOODIE_ARTICLE_ID = $('Edit Fields').first().json.goodieArticleId;\nconst GOODIE_ORDER_PREFIX = $('Edit Fields').first().json.goodieOrderPrefix;\n\n// Check if we should add goodie items (global check on input)\nconst shouldAddGoodie = $input.first().json.result?.length === 0;\n\nfunction getCustomAttr(attrs, id) {\n  return (attrs || []).find(a => String(a.attributeDefinitionId) === String(id));\n}\n\nconst sourceItems = $('Split Out salesOrders1').all();\n\nreturn sourceItems.map((src, idx) => {\n  // work on a copy\n  const order = JSON.parse(JSON.stringify(src.json));\n\n  const updatedOrderItems = [];\n  let rcSum = 0;\n  let hasPAItem = false;\n\n  // NEW: warehouseId detection\n  let foundWarehouseId;\n\n  // Track for customAttribute check\n  let allCustomAttrTrue = true;  // assume true until false\n  let sawQualifyingItem = false; // at least one item with articleNumber\n\n  // ---- Pass 1: analyze items\n  for (const oi of order.orderItems || []) {\n    const hasArticleNumber = typeof oi.articleNumber === 'string' && oi.articleNumber.trim() !== '';\n\n    // RC- sum\n    if (hasArticleNumber && oi.articleNumber.startsWith('RC-')) {\n      const qty = oi.quantity !== undefined ? Number(oi.quantity) : 0;\n      if (!isNaN(qty)) rcSum += qty;\n    }\n\n    // PA- present?\n    if (hasArticleNumber && oi.articleNumber.startsWith('PA-')) {\n      hasPAItem = true;\n    }\n\n    // find warehouseId once\n    if (!foundWarehouseId) {\n      const attrWarehouse = getCustomAttr(oi.customAttributes, WAREHOUSE_ID_DEF);\n      const val = attrWarehouse?.stringValue?.trim?.();\n      if (val) foundWarehouseId = val;\n    }\n\n    // customAttribute (Kein Versand) only when item has articleNumber\n    if (hasArticleNumber) {\n      sawQualifyingItem = true;\n      const attr90699 = getCustomAttr(oi.customAttributes, CUSTOM_ATTR_CHECK_ID);\n      if (!attr90699 || attr90699.booleanValue !== true) {\n        allCustomAttrTrue = false;\n      }\n    }\n  }\n\n  // ---- Pass 2: build outgoing orderItems (only keep id for existing items)\n  for (const oi of order.orderItems || []) {\n    updatedOrderItems.push({ id: oi.id });\n  }\n\n  // ---- Packaging logic: add PA-* if there are RC-* items and no PA-* exists yet\n  if (rcSum > 0 && !hasPAItem) {\n    const packagingArticle = rcSum <= 12 ? 'PA-11003-01' : 'PA-11004-01';\n    updatedOrderItems.push({\n      articleNumber: packagingArticle,\n      quantity: '1',\n    });\n  }\n\n  // ---- Goodie logic: add goodie item if result is empty and orderNumber matches prefix AND has RC items\n  if (shouldAddGoodie && GOODIE_ORDER_PREFIX && order.orderNumber?.startsWith(GOODIE_ORDER_PREFIX) && rcSum > 0) {\n    updatedOrderItems.push({\n      articleId: GOODIE_ARTICLE_ID,\n      quantity: '1',\n    });\n  }\n\n  // ---- Set/clear warehouseId on order\n  if (foundWarehouseId) {\n    order.warehouseId = foundWarehouseId;\n  } else {\n    delete order.warehouseId;\n  }\n\n  // ---- fulfillmentProviderId null logic\n  if (sawQualifyingItem && allCustomAttrTrue) {\n    order.fulfillmentProviderId = null;\n    order.shipmentMethodId = null;\n    order.shipmentMethodName = null;\n    order.defaultShippingCarrierId = null;\n    order.defaultShippingCarrierName = null;\n    order.defaultShippingReturnCarrierId = null;\n    order.defaultShippingReturnCarrierName = null;\n  }\n\n  // ---- Common updates\n  order.status = 'ORDER_CONFIRMATION_PRINTED';\n  order.customAttributes = [{ attributeDefinitionId: $('Edit Fields').first().json.additionalField_VerpackungAngepasst, booleanValue: true }];\n  order.orderItems = updatedOrderItems;\n\n  return { json: order, pairedItem: { item: idx } };\n});\n"
      }
    },
