        "jsCode": "// Cost Center IDs for B2B and B2C\nconst COST_CENTER_B2B = $('Edit Fields').first().json.constCenter_b2b;\nconst COST_CENTER_B2C = $('Edit Fields').first().json.costCenter_b2c;\n\nconst input = $input.all();\nconst result = [];\n\nfor (const item of input) {\n    const recordAddress = item.json.recordAddress || {};\n    const salesInvoiceItems = Array.isArray(item.json.salesInvoiceItems) ? item.json.salesInvoiceItems : [];\n    const updatedItems = [];\n\n    for (const sii of salesInvoiceItems) {\n        let cost2CostCenterId = sii.cost2CostCenterId;\n        if (!cost2CostCenterId) {\n            cost2CostCenterId = recordAddress.company ? COST_CENTER_B2B : COST_CENTER_B2C;\n        }\n        const newItem = { id: sii.id };\n        if (cost2CostCenterId !== undefined) {\n            newItem.cost2CostCenterId = cost2CostCenterId;\n        }\n        updatedItems.push(newItem);\n    }\n\n    result.push({\n        json: { id: item.json.id, status: 'DOCUMENT_CREATED', salesInvoiceItems: updatedItems },\n        pairedItem: { item: item.pairedItem?.item ?? 0 }\n    });\n}\n\nreturn result;"
      }
    },
