              "leftValue": "={{ (() => { const moduleAttrId = $('Constants').item.json.moduleAttributeId; const allowed = String($('Constants').item.json.allowedModuleValues || '').split(','); const attrs = Array.isArray($json.customAttributes) ? $json.customAttributes : []; const moduleAttr = attrs.find(a => String(a.attributeDefinitionId) === moduleAttrId); if (!moduleAttr) return false; const selected = Array.isArray(moduleAttr.selectedValues) ? moduleAttr.selectedValues : []; return selected.some(sv => allowed.includes(String(sv.id))); })() }}",
              "rightValue": "",
