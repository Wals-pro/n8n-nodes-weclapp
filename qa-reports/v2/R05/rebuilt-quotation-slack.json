    {
      "id": "qa2r05-build-message",
      "name": "Build Slack message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        752,
        160
      ],
      "parameters": {
        "jsCode": "const constants = $('Constants').first().json;\nconst q = $('weclapp get quotation').first().json;\nconst opp = $('weclapp get opportunity').first().json;\n\nconst baseUrl = constants.weclappBaseUrl;\nconst quotationLink = baseUrl + '/app/quotation/' + q.id;\nconst num = q.quotationNumber || '';\n\nconst oppName = opp && opp.name && !opp.error ? String(opp.name) : '';\nconst oppId = opp && opp.id ? opp.id : q.opportunityId;\nconst opportunityLink = oppId && oppName ? baseUrl + '/app/opportunity/' + oppId : '';\n\nconst projAttr = (q.customAttributes || []).find(\n  a => String(a.attributeDefinitionId) === constants.projectNameAttributeId\n);\nconst projName = projAttr ? String(projAttr.stringValue || '') : '';\n\nfunction fmtDate(ms) {\n  if (!ms) return null;\n  const d = new Date(ms);\n  return String(d.getDate()).padStart(2, '0') + '.' + String(d.getMonth() + 1).padStart(2, '0') + '.' + d.getFullYear();\n}\nconst spFrom = fmtDate(q.servicePeriodFrom);\nconst spTo = fmtDate(q.servicePeriodTo);\n\nconst lines = [];\nlines.push('Angebot <' + quotationLink + '|' + num + '> wurde soeben angenommen!');\nif (oppName) {\n  lines.push(opportunityLink ? 'Chance: <' + opportunityLink + '|' + oppName + '>' : 'Chance: ' + oppName);\n}\nif (projName) lines.push('Projekt: ' + projName);\nif (spFrom && spTo) lines.push('Leistungszeitraum: ' + spFrom + ' - ' + spTo);\n\nconst slackText = lines.join('\\n');\n\nlet slackMarketingText = slackText;\nconst mktItem = (q.quotationItems || []).find(\n  item => String(item.articleId) === constants.marketingArticleId\n);\nif (mktItem) {\n  const raw = String(mktItem.description || '');\n  const plain = raw\n    .replace(/<\\/li>\\s*<li>/gi, '\\n- ').replace(/<li>/gi, '- ').replace(/<\\/li>/gi, '')\n    .replace(/<br\\s*\\/?>/gi, '\\n').replace(/<\\/p>\\s*<p>/gi, '\\n').replace(/<[^>]+>/g, '')\n    .replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&nbsp;/g, ' ')\n    .replace(/[ \\t]+$/gm, '').replace(/\\n{2,}/g, '\\n').trim();\n  slackMarketingText += '\\n\\nEs wurde ein Marketing-Paket vereinbart mit folgendem Inhalt:\\n' + plain;\n}\n\nreturn [{\n  json: {\n    quotationId: String(q.id || ''),\n    quotationNumber: num,\n    quotationLink,\n    opportunityName: oppName,\n    projectName: projName,\n    slackText,\n    slackMarketingText,\n  },\n  pairedItem: { item: 0 },\n}];"
      }
    },
