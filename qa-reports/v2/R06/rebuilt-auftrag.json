    {
      "id": "28e53341-ab20-4b1f-9d9a-7dbb02968ebf",
      "name": "Code",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [112, 528],
      "parameters": {
        "jsCode": "// n8n Code node (JavaScript) - v2 rebuild\n// Reads from weclapp get salesOrder ORDER_ENTRY_IN_PROGRESS (individual items, list already unwrapped)\n// $input = result of weclapp check customer goodie orders (alwaysOutputData:true, may be empty {})\n\nconst WAREHOUSE_ID_DEF = $('Constants').first().json.WAREHOUSE_ID_DEF;\nconst CUSTOM_ATTR_CHECK_ID = $('Constants').first().json.additionalField_KeinVersand;\nconst GOODIE_ARTICLE_ID = $('Constants').first().json.goodieArticleId;\nconst GOODIE_ORDER_PREFIX = $('Constants').first().json.goodieOrderPrefix;\n\n// v2: goodie check — alwaysOutputData means we always get an item.\n// If the customer already has a goodie order, $input.first().json.id is defined.\n// If not (empty list), $input.first().json.id is undefined.\nconst shouldAddGoodie = !$input.first().json.id;\n\nfunction getCustomAttr(attrs, id) {\n  return (attrs || []).find(a => String(a.attributeDefinitionId) === String(id));\n}\n\n// The source order is the current item from the list node (paired via goodie check node)\nconst order = JSON.parse(JSON.stringify($('weclapp get salesOrder ORDER_ENTRY_IN_PROGRESS').item.json));\n\nconst updatedOrderItems = [];\nlet rcSum = 0;\nlet hasPAItem = false;\nlet foundWarehouseId;\nlet allCustomAttrTrue = true;\nlet sawQualifyingItem = false;\n\n// ---- Pass 1: analyze items\nfor (const oi of order.orderItems || []) {\n  const hasArticleNumber = typeof oi.articleNumber === 'string' && oi.articleNumber.trim() !== '';\n\n  if (hasArticleNumber && oi.articleNumber.startsWith('RC-')) {\n    const qty = oi.quantity !== undefined ? Number(oi.quantity) : 0;\n    if (!isNaN(qty)) rcSum += qty;\n  }\n\n  if (hasArticleNumber && oi.articleNumber.startsWith('PA-')) {\n    hasPAItem = true;\n  }\n\n  if (!foundWarehouseId) {\n    const attrWarehouse = getCustomAttr(oi.customAttributes, WAREHOUSE_ID_DEF);\n    const val = attrWarehouse?.stringValue?.trim?.();\n    if (val) foundWarehouseId = val;\n  }\n\n  if (hasArticleNumber) {\n    sawQualifyingItem = true;\n    const attrKeinVersand = getCustomAttr(oi.customAttributes, CUSTOM_ATTR_CHECK_ID);\n    if (!attrKeinVersand || attrKeinVersand.booleanValue !== true) {\n      allCustomAttrTrue = false;\n    }\n  }\n}\n\n// ---- Pass 2: build outgoing orderItems\nfor (const oi of order.orderItems || []) {\n  updatedOrderItems.push({ id: oi.id });\n}\n\n// ---- Packaging logic\nif (rcSum > 0 && !hasPAItem) {\n  const packagingArticle = rcSum <= 12 ? 'PA-11003-01' : 'PA-11004-01';\n  updatedOrderItems.push({ articleNumber: packagingArticle, quantity: '1' });\n}\n\n// ---- Goodie logic\nif (shouldAddGoodie && GOODIE_ORDER_PREFIX && order.orderNumber?.startsWith(GOODIE_ORDER_PREFIX) && rcSum > 0) {\n  updatedOrderItems.push({ articleId: GOODIE_ARTICLE_ID, quantity: '1' });\n}\n\n// ---- Warehouse\nif (foundWarehouseId) {\n  order.warehouseId = foundWarehouseId;\n} else {\n  delete order.warehouseId;\n}\n\n// ---- No-delivery logic\nif (sawQualifyingItem && allCustomAttrTrue) {\n  order.fulfillmentProviderId = null;\n  order.shipmentMethodId = null;\n  order.shipmentMethodName = null;\n  order.defaultShippingCarrierId = null;\n  order.defaultShippingCarrierName = null;\n  order.defaultShippingReturnCarrierId = null;\n  order.defaultShippingReturnCarrierName = null;\n}\n\n// ---- Common updates\norder.status = 'ORDER_CONFIRMATION_PRINTED';\norder.customAttributes = [{ attributeDefinitionId: $('Constants').first().json.additionalField_VerpackungAngepasst, booleanValue: true }];\norder.orderItems = updatedOrderItems;\n\nreturn [{ json: order, pairedItem: { item: 0 } }];\n"
      }
    },
