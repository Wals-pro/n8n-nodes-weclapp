    {
      "id": "979e97fc-84f9-4faa-ae87-9b115e545129",
      "name": "Code1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-112, 2432],
      "parameters": {
        "jsCode": "// Cost Center IDs for B2B and B2C\nconst COST_CENTER_B2B = $('Constants').first().json.constCenter_b2b;\nconst COST_CENTER_B2C = $('Constants').first().json.costCenter_b2c;\n\n// v2: input is already individual items from list (rootProperty postReceive unwraps)\nconst result = [];\n\nfor (const item of $input.all()) {\n    const recordAddress = item.json.recordAddress || {};\n    const salesInvoiceItems = Array.isArray(item.json.salesInvoiceItems) ? item.json.salesInvoiceItems : [];\n    const updatedItems = [];\n\n    for (const sii of salesInvoiceItems) {\n        let cost2CostCenterId = sii.cost2CostCenterId;\n\n        if (!cost2CostCenterId) {\n            if (recordAddress.company) {\n                cost2CostCenterId = COST_CENTER_B2B;\n            } else {\n                cost2CostCenterId = COST_CENTER_B2C;\n            }\n        }\n\n        const newItem = { id: sii.id };\n        if (cost2CostCenterId !== undefined) {\n            newItem.cost2CostCenterId = cost2CostCenterId;\n        }\n        updatedItems.push(newItem);\n    }\n\n    result.push({\n        json: {\n            id: item.json.id,\n            status: \"DOCUMENT_CREATED\",\n            salesInvoiceItems: updatedItems\n        },\n        pairedItem: item.pairedItem\n    });\n}\n\nreturn result;"
      }
    },
